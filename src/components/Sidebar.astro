---
// No props — all filter state is managed client-side via the inline script in index.astro
---

<aside class="sidebar" id="sidebar">
  <!-- Search -->
  <input
    type="text"
    class="search-input"
    id="search"
    placeholder="Search make, model, variant..."
  />

  <!-- Sort -->
  <div class="filter-section">
    <div class="filter-header">
      Sort by <span class="chevron">▼</span>
    </div>
    <div class="filter-body">
      <select class="sort-select" id="sortBy">
        <option value="price-asc">Price: Low → High</option>
        <option value="price-desc">Price: High → Low</option>
        <option value="range-desc">Range: Highest first</option>
        <option value="range-asc">Range: Lowest first</option>
        <option value="power-desc">Power: Highest first</option>
        <option value="speed-asc">0-100 km/h: Fastest first</option>
        <option value="efficiency-asc">Efficiency: Best first</option>
        <option value="dccharger-desc">DC Charging: Fastest first</option>
        <option value="battery-desc">Battery: Largest first</option>
        <option value="weight-asc">Weight: Lightest first</option>
        <option value="price_per_km-asc">Price/km: Best value first</option>
        <option value="boot-desc">Boot: Largest first</option>
        <option value="name-asc">Name: A → Z</option>
      </select>
    </div>
  </div>

  <!-- Price -->
  <div class="filter-section">
    <div class="filter-header">
      Price (NZD) <span class="chevron">▼</span>
    </div>
    <div class="filter-body">
      <div class="range-filter">
        <div class="range-labels">
          <span>Min: <span class="val" id="priceMinVal">$0</span></span>
          <span>Max: <span class="val" id="priceMaxVal">$750k</span></span>
        </div>
        <div class="range-inputs">
          <input type="range" id="priceMin" min="0" max="750000" step="5000" value="0" />
          <input type="range" id="priceMax" min="0" max="750000" step="5000" value="750000" />
        </div>
      </div>
    </div>
  </div>

  <!-- Range -->
  <div class="filter-section">
    <div class="filter-header">
      Range (km) <span class="chevron">▼</span>
    </div>
    <div class="filter-body">
      <div class="range-filter">
        <div class="range-labels">
          <span>Min: <span class="val" id="rangeMinVal">0 km</span></span>
        </div>
        <input type="range" id="rangeMin" min="0" max="800" step="10" value="0" />
      </div>
    </div>
  </div>

  <!-- Power -->
  <div class="filter-section">
    <div class="filter-header">
      Power (kW) <span class="chevron">▼</span>
    </div>
    <div class="filter-body">
      <div class="range-filter">
        <div class="range-labels">
          <span>Min: <span class="val" id="powerMinVal">0 kW</span></span>
        </div>
        <input type="range" id="powerMin" min="0" max="800" step="10" value="0" />
      </div>
    </div>
  </div>

  <!-- Battery -->
  <div class="filter-section">
    <div class="filter-header">
      Battery (kWh) <span class="chevron">▼</span>
    </div>
    <div class="filter-body">
      <div class="range-filter">
        <div class="range-labels">
          <span>Min: <span class="val" id="batteryMinVal">0 kWh</span></span>
        </div>
        <input type="range" id="batteryMin" min="0" max="130" step="5" value="0" />
      </div>
    </div>
  </div>

  <!-- DC Charging -->
  <div class="filter-section">
    <div class="filter-header">
      DC Charging (kW) <span class="chevron">▼</span>
    </div>
    <div class="filter-body">
      <div class="range-filter">
        <div class="range-labels">
          <span>Min: <span class="val" id="dcMinVal">0 kW</span></span>
        </div>
        <input type="range" id="dcMin" min="0" max="500" step="10" value="0" />
      </div>
    </div>
  </div>

  <!-- 0-100 Speed -->
  <div class="filter-section">
    <div class="filter-header">
      0-100 km/h (sec) <span class="chevron">▼</span>
    </div>
    <div class="filter-body">
      <div class="range-filter">
        <div class="range-labels">
          <span>Max: <span class="val" id="speedMaxVal">20 s</span></span>
        </div>
        <input type="range" id="speedMax" min="2" max="20" step="0.5" value="20" />
      </div>
    </div>
  </div>

  <!-- Efficiency -->
  <div class="filter-section">
    <div class="filter-header">
      Efficiency (Wh/km) <span class="chevron">▼</span>
    </div>
    <div class="filter-body">
      <div class="range-filter">
        <div class="range-labels">
          <span>Max: <span class="val" id="effMaxVal">350 Wh/km</span></span>
        </div>
        <input type="range" id="effMax" min="100" max="350" step="5" value="350" />
      </div>
    </div>
  </div>

  <!-- Boot / Cargo -->
  <div class="filter-section">
    <div class="filter-header">
      Boot Space (L) <span class="chevron">▼</span>
    </div>
    <div class="filter-body">
      <div class="range-filter">
        <div class="range-labels">
          <span>Min: <span class="val" id="bootMinVal">0 L</span></span>
        </div>
        <input type="range" id="bootMin" min="0" max="1400" step="50" value="0" />
      </div>
    </div>
  </div>

  <!-- Towing -->
  <div class="filter-section">
    <div class="filter-header">
      Towing — Braked (kg) <span class="chevron">▼</span>
    </div>
    <div class="filter-body">
      <div class="range-filter">
        <div class="range-labels">
          <span>Min: <span class="val" id="towMinVal">0 kg</span></span>
        </div>
        <input type="range" id="towMin" min="0" max="3000" step="100" value="0" />
      </div>
      <div class="toggle-row">
        <span>Must have towing</span>
        <div class="toggle" id="towRequired"></div>
      </div>
    </div>
  </div>

  <!-- Seats -->
  <div class="filter-section">
    <div class="filter-header">Seats <span class="chevron">▼</span></div>
    <div class="filter-body">
      <div class="checkbox-grid" id="seatsFilter"></div>
    </div>
  </div>

  <!-- Make -->
  <div class="filter-section">
    <div class="filter-header">Make <span class="chevron">▼</span></div>
    <div class="filter-body">
      <div class="checkbox-grid" id="makeFilter"></div>
    </div>
  </div>

  <!-- Body Style -->
  <div class="filter-section">
    <div class="filter-header">
      Body Style <span class="chevron">▼</span>
    </div>
    <div class="filter-body">
      <div class="checkbox-grid" id="shapeFilter"></div>
    </div>
  </div>

  <!-- Drivetrain -->
  <div class="filter-section">
    <div class="filter-header">
      Drivetrain <span class="chevron">▼</span>
    </div>
    <div class="filter-body">
      <div class="checkbox-grid" id="driveFilter"></div>
    </div>
  </div>

  <!-- Battery Chemistry -->
  <div class="filter-section">
    <div class="filter-header">
      Battery Chemistry <span class="chevron">▼</span>
    </div>
    <div class="filter-body">
      <div class="checkbox-grid" id="chemFilter"></div>
    </div>
  </div>

  <!-- Year -->
  <div class="filter-section">
    <div class="filter-header">Year <span class="chevron">▼</span></div>
    <div class="filter-body">
      <div class="checkbox-grid" id="yearFilter"></div>
    </div>
  </div>

  <!-- Features -->
  <div class="filter-section">
    <div class="filter-header">
      Features <span class="chevron">▼</span>
    </div>
    <div class="filter-body">
      <div class="toggle-row">
        <span>V2L (Vehicle to Load)</span>
        <div class="toggle" id="v2lRequired"></div>
      </div>
      <div class="toggle-row">
        <span>Has frunk</span>
        <div class="toggle" id="frunkRequired"></div>
      </div>
    </div>
  </div>

  <!-- AC Charger -->
  <div class="filter-section">
    <div class="filter-header">
      AC Charger (kW) <span class="chevron">▼</span>
    </div>
    <div class="filter-body">
      <div class="range-filter">
        <div class="range-labels">
          <span>Min: <span class="val" id="acMinVal">0 kW</span></span>
        </div>
        <input type="range" id="acMin" min="0" max="22" step="1" value="0" />
      </div>
    </div>
  </div>

  <!-- Weight -->
  <div class="filter-section">
    <div class="filter-header">
      Weight (kg) <span class="chevron">▼</span>
    </div>
    <div class="filter-body">
      <div class="range-filter">
        <div class="range-labels">
          <span>Max: <span class="val" id="weightMaxVal">3100 kg</span></span>
        </div>
        <input type="range" id="weightMax" min="1000" max="3100" step="50" value="3100" />
      </div>
    </div>
  </div>

  <!-- Ground Clearance -->
  <div class="filter-section">
    <div class="filter-header">
      Ground Clearance (mm) <span class="chevron">▼</span>
    </div>
    <div class="filter-body">
      <div class="range-filter">
        <div class="range-labels">
          <span>Min: <span class="val" id="groundMinVal">0 mm</span></span>
        </div>
        <input type="range" id="groundMin" min="0" max="260" step="10" value="0" />
      </div>
    </div>
  </div>

  <!-- Length -->
  <div class="filter-section">
    <div class="filter-header">
      Length (mm) <span class="chevron">▼</span>
    </div>
    <div class="filter-body">
      <div class="range-filter">
        <div class="range-labels">
          <span>Max: <span class="val" id="lengthMaxVal">6000 mm</span></span>
        </div>
        <input type="range" id="lengthMax" min="3000" max="6000" step="100" value="6000" />
      </div>
      <div class="range-filter">
        <div class="range-labels">
          <span>Min: <span class="val" id="lengthMinVal">0 mm</span></span>
        </div>
        <input type="range" id="lengthMin" min="0" max="6000" step="100" value="0" />
      </div>
    </div>
  </div>

  <!-- Width -->
  <div class="filter-section">
    <div class="filter-header">
      Width (mm) <span class="chevron">▼</span>
    </div>
    <div class="filter-body">
      <div class="range-filter">
        <div class="range-labels">
          <span>Max: <span class="val" id="widthMaxVal">2200 mm</span></span>
        </div>
        <input type="range" id="widthMax" min="1600" max="2200" step="20" value="2200" />
      </div>
    </div>
  </div>

  <!-- Height -->
  <div class="filter-section">
    <div class="filter-header">
      Height (mm) <span class="chevron">▼</span>
    </div>
    <div class="filter-body">
      <div class="range-filter">
        <div class="range-labels">
          <span>Max: <span class="val" id="heightMaxVal">2600 mm</span></span>
        </div>
        <input type="range" id="heightMax" min="1300" max="2600" step="20" value="2600" />
      </div>
    </div>
  </div>

  <!-- Top Speed -->
  <div class="filter-section">
    <div class="filter-header">
      Top Speed (km/h) <span class="chevron">▼</span>
    </div>
    <div class="filter-body">
      <div class="range-filter">
        <div class="range-labels">
          <span>Min: <span class="val" id="topspeedMinVal">0 km/h</span></span>
        </div>
        <input type="range" id="topspeedMin" min="0" max="300" step="10" value="0" />
      </div>
    </div>
  </div>

  <!-- Torque -->
  <div class="filter-section">
    <div class="filter-header">
      Torque (Nm) <span class="chevron">▼</span>
    </div>
    <div class="filter-body">
      <div class="range-filter">
        <div class="range-labels">
          <span>Min: <span class="val" id="torqueMinVal">0 Nm</span></span>
        </div>
        <input type="range" id="torqueMin" min="0" max="1300" step="50" value="0" />
      </div>
    </div>
  </div>

  <button class="reset-btn" id="resetBtn">Reset All Filters</button>
</aside>

<style>
  .sidebar {
    width: 340px;
    min-width: 340px;
    background: var(--surface);
    border-right: 1px solid var(--border);
    overflow-y: auto;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .filter-section {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .filter-header {
    padding: 10px 14px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-dim);
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    user-select: none;
    background: var(--surface2);
  }
  .filter-header:hover {
    color: var(--text);
  }
  .filter-header .chevron {
    transition: transform 0.2s;
    font-size: 10px;
  }
  .filter-header.collapsed .chevron {
    transform: rotate(-90deg);
  }
  .filter-body {
    padding: 10px 14px 14px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .filter-body.hidden {
    display: none;
  }

  /* Range sliders */
  .range-filter {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .range-labels {
    display: flex;
    justify-content: space-between;
    font-size: 12px;
    color: var(--text-dim);
  }
  .range-labels .val {
    color: var(--accent);
    font-weight: 600;
  }
  .range-inputs {
    display: flex;
    gap: 8px;
    align-items: center;
  }
  .range-inputs input[type="range"],
  .range-filter > input[type="range"] {
    flex: 1;
    width: 100%;
    -webkit-appearance: none;
    appearance: none;
    height: 4px;
    background: var(--border);
    border-radius: 2px;
    outline: none;
  }
  .range-inputs input[type="range"]::-webkit-slider-thumb,
  .range-filter > input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--accent);
    cursor: pointer;
    border: 2px solid var(--bg);
  }

  /* Checkboxes / chips */
  .checkbox-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  /* Toggle */
  .toggle-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 13px;
  }
  .toggle {
    width: 36px;
    height: 20px;
    background: var(--border);
    border-radius: 10px;
    cursor: pointer;
    position: relative;
    transition: background 0.2s;
  }
  .toggle.active {
    background: var(--accent);
  }
  .toggle::after {
    content: "";
    position: absolute;
    top: 2px;
    left: 2px;
    width: 16px;
    height: 16px;
    background: #fff;
    border-radius: 50%;
    transition: left 0.2s;
  }
  .toggle.active::after {
    left: 18px;
  }

  /* Sort */
  .sort-select {
    width: 100%;
    padding: 8px 12px;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: var(--surface2);
    color: var(--text);
    font-size: 13px;
    cursor: pointer;
  }

  /* Search */
  .search-input {
    width: 100%;
    padding: 10px 14px;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--surface2);
    color: var(--text);
    font-size: 14px;
    outline: none;
  }
  .search-input:focus {
    border-color: var(--accent);
  }
  .search-input::placeholder {
    color: var(--text-dim);
  }

  /* Reset button */
  .reset-btn {
    width: 100%;
    padding: 10px;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-dim);
    font-size: 13px;
    cursor: pointer;
    transition: all 0.15s;
  }
  .reset-btn:hover {
    border-color: var(--red);
    color: var(--red);
  }

  /* Mobile */
  @media (max-width: 900px) {
    .sidebar {
      position: fixed;
      top: 57px;
      left: 0;
      bottom: 0;
      z-index: 150;
      transform: translateX(-100%);
      transition: transform 0.3s;
      box-shadow: 4px 0 20px rgba(0, 0, 0, 0.5);
    }
    .sidebar.open {
      transform: translateX(0);
    }
  }
</style>
