---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import EVGrid from '../components/EVGrid.astro';
import { EV_DATA } from '../data/data.js';
---

<BaseLayout title="NZ EV Finder Search">
  <Header totalCount={EV_DATA.length} />

  <div class="layout">
    <Sidebar />
    <EVGrid />
  </div>

  <button class="sidebar-toggle" id="sidebarToggle">⚡</button>

  <script type="application/json" id="ev-data" set:html={JSON.stringify(EV_DATA)} is:inline></script>

  <script>
    const EV_DATA = JSON.parse(document.getElementById("ev-data")!.textContent!);

    // --- State ---
    let filters = getDefaultFilters();
    let chipSelections = {
      make: new Set(),
      shape: new Set(),
      drivetrain: new Set(),
      chem: new Set(),
      seats: new Set(),
      year: new Set(),
    };

    function getDefaultFilters() {
      return {
        search: "",
        priceMin: 0,
        priceMax: 750000,
        rangeMin: 0,
        powerMin: 0,
        batteryMin: 0,
        dcMin: 0,
        speedMax: 20,
        effMax: 350,
        bootMin: 0,
        towMin: 0,
        towRequired: false,
        acMin: 0,
        weightMax: 3100,
        groundMin: 0,
        topspeedMin: 0,
        torqueMin: 0,
        v2lRequired: false,
        frunkRequired: false,
        lengthMin: 0,
        lengthMax: 6000,
        widthMax: 2200,
        heightMax: 2600,
        sortBy: "price-asc",
      };
    }

    // --- Types ---
    interface EV {
      [key: string]: unknown;
      name: string;
      make_name: string;
      model_name: string;
      year: number | string;
      url?: string;
      image_url?: string;
      price: number;
      range?: number | null;
      power?: number | null;
      battery?: number | null;
      dccharger?: number | null;
      speed?: number | null;
      efficiency?: number | null;
      boot?: number | null;
      tow_brake?: number | null;
      charger?: number | null;
      weight?: number | null;
      ground?: number | null;
      lengthmm?: number | null;
      width?: number | null;
      height?: number | null;
      topspeed?: number | null;
      torque?: number | null;
      v2l?: string | number | null;
      frunk?: number | null;
      shape?: string;
      drivetrain?: string;
      chem?: string;
      seats?: number | string;
    }

    // --- Helpers ---
    function fmtPrice(n: number | null | undefined): string {
      if (n == null) return "—";
      return "$" + n.toLocaleString("en-NZ", { maximumFractionDigits: 0 });
    }

    // --- Build chip filters ---
    function buildChips(containerId: string, values: Set<unknown>, key: keyof typeof chipSelections) {
      const container = document.getElementById(containerId);
      if (!container) return;
      const sorted = [...values].sort((a, b) =>
        String(a).localeCompare(String(b), undefined, { numeric: true }),
      );
      container.innerHTML = sorted
        .map(
          (v) =>
            `<span class="chip" data-key="${key}" data-value="${v}">${v}</span>`,
        )
        .join("");
      container.addEventListener("click", (e) => {
        const chip = (e.target as Element | null)?.closest(".chip");
        if (!chip) return;
        const val = (chip as HTMLElement).dataset.value;
        const set = chipSelections[key];
        if (set.has(val)) {
          set.delete(val);
          chip.classList.remove("active");
        } else {
          set.add(val);
          chip.classList.add("active");
        }
        applyFilters();
      });
    }

    // --- Init chips ---
    function initChips() {
      const makes = new Set(),
        shapes = new Set(),
        drives = new Set(),
        chems = new Set(),
        seats = new Set(),
        years = new Set();
      EV_DATA.forEach((ev: any) => {
        if (ev.make_name) makes.add(ev.make_name);
        if (ev.shape) shapes.add(ev.shape);
        if (ev.drivetrain) drives.add(ev.drivetrain);
        if (ev.chem) chems.add(ev.chem);
        if (ev.seats) seats.add(String(ev.seats));
        if (ev.year) years.add(ev.year);
      });
      buildChips("makeFilter", makes, "make");
      buildChips("shapeFilter", shapes, "shape");
      buildChips("driveFilter", drives, "drivetrain");
      buildChips("chemFilter", chems, "chem");
      buildChips("seatsFilter", seats, "seats");
      buildChips("yearFilter", years, "year");
    }

    // --- Collapsible sections ---
    function initCollapsible() {
      document.querySelectorAll(".filter-header").forEach((header) => {
        header.addEventListener("click", () => {
          header.classList.toggle("collapsed");
          header.nextElementSibling?.classList.toggle("hidden");
        });
      });
    }

    // --- Toggles ---
    function initToggles() {
      (["towRequired", "v2lRequired", "frunkRequired"] as const).forEach((id) => {
        document.getElementById(id)?.addEventListener("click", function (this: HTMLElement) {
          this.classList.toggle("active");
          (filters as Record<string, unknown>)[id] = this.classList.contains("active");
          applyFilters();
        });
      });
    }

    // --- Range sliders ---
    function initSliders() {
      const sliders = [
        { id: "priceMin",     label: "priceMinVal",    fmt: (v: string) => fmtPrice(+v),    key: "priceMin" },
        { id: "priceMax",     label: "priceMaxVal",    fmt: (v: string) => fmtPrice(+v),    key: "priceMax" },
        { id: "rangeMin",     label: "rangeMinVal",    fmt: (v: string) => v + " km",       key: "rangeMin" },
        { id: "powerMin",     label: "powerMinVal",    fmt: (v: string) => v + " kW",       key: "powerMin" },
        { id: "batteryMin",   label: "batteryMinVal",  fmt: (v: string) => v + " kWh",      key: "batteryMin" },
        { id: "dcMin",        label: "dcMinVal",       fmt: (v: string) => v + " kW",       key: "dcMin" },
        { id: "speedMax",     label: "speedMaxVal",    fmt: (v: string) => v + " s",        key: "speedMax" },
        { id: "effMax",       label: "effMaxVal",      fmt: (v: string) => v + " Wh/km",   key: "effMax" },
        { id: "bootMin",      label: "bootMinVal",     fmt: (v: string) => v + " L",        key: "bootMin" },
        { id: "towMin",       label: "towMinVal",      fmt: (v: string) => v + " kg",       key: "towMin" },
        { id: "acMin",        label: "acMinVal",       fmt: (v: string) => v + " kW",       key: "acMin" },
        { id: "weightMax",    label: "weightMaxVal",   fmt: (v: string) => v + " kg",       key: "weightMax" },
        { id: "groundMin",    label: "groundMinVal",   fmt: (v: string) => v + " mm",       key: "groundMin" },
        { id: "topspeedMin",  label: "topspeedMinVal", fmt: (v: string) => v + " km/h",    key: "topspeedMin" },
        { id: "torqueMin",    label: "torqueMinVal",   fmt: (v: string) => v + " Nm",       key: "torqueMin" },
        { id: "lengthMin",    label: "lengthMinVal",   fmt: (v: string) => v + " mm",       key: "lengthMin" },
        { id: "lengthMax",    label: "lengthMaxVal",   fmt: (v: string) => v + " mm",       key: "lengthMax" },
        { id: "widthMax",     label: "widthMaxVal",    fmt: (v: string) => v + " mm",       key: "widthMax" },
        { id: "heightMax",    label: "heightMaxVal",   fmt: (v: string) => v + " mm",       key: "heightMax" },
      ];
      sliders.forEach((s) => {
        const el = document.getElementById(s.id) as HTMLInputElement | null;
        const lbl = document.getElementById(s.label);
        if (!el || !lbl) return;
        el.addEventListener("input", () => {
          lbl.textContent = s.fmt(el.value);
          (filters as Record<string, unknown>)[s.key] = +el.value;
          applyFilters();
        });
      });
    }

    // --- Search ---
    function initSearch() {
      document.getElementById("search")?.addEventListener("input", (e) => {
        filters.search = (e.target as HTMLInputElement).value.toLowerCase();
        applyFilters();
      });
    }

    // --- Sort ---
    function initSort() {
      document.getElementById("sortBy")?.addEventListener("change", (e) => {
        filters.sortBy = (e.target as HTMLSelectElement).value;
        applyFilters();
      });
    }

    // --- Reset ---
    function initReset() {
      document.getElementById("resetBtn")?.addEventListener("click", () => {
        filters = getDefaultFilters();
        chipSelections = {
          make: new Set(),
          shape: new Set(),
          drivetrain: new Set(),
          chem: new Set(),
          seats: new Set(),
          year: new Set(),
        };
        (document.getElementById("search") as HTMLInputElement | null)!.value = "";
        (document.getElementById("sortBy") as HTMLSelectElement | null)!.value = "price-asc";
        document.querySelectorAll(".chip.active").forEach((c) => c.classList.remove("active"));
        document.querySelectorAll(".toggle.active").forEach((t) => t.classList.remove("active"));
        const defaults: Record<string, number> = {
          priceMin: 0, priceMax: 750000, rangeMin: 0, powerMin: 0, batteryMin: 0,
          dcMin: 0, speedMax: 20, effMax: 350, bootMin: 0, towMin: 0, acMin: 0,
          weightMax: 3100, groundMin: 0, lengthMin: 0, lengthMax: 6000,
          widthMax: 2200, heightMax: 2600, topspeedMin: 0, torqueMin: 0,
        };
        Object.entries(defaults).forEach(([k, v]) => {
          const el = document.getElementById(k) as HTMLInputElement | null;
          if (el) el.value = String(v);
        });
        document.querySelectorAll('input[type="range"]').forEach((el) => el.dispatchEvent(new Event("input")));
        applyFilters();
      });
    }

    // --- Filter logic ---
    function matchesFilters(ev: EV) {
      const f = filters;
      if (f.search) {
        const hay = `${ev.name} ${ev.make_name} ${ev.model_name} ${ev.shape} ${ev.drivetrain}`.toLowerCase();
        if (!hay.includes(f.search)) return false;
      }
      if (ev.price < f.priceMin || ev.price > f.priceMax) return false;
      if (ev.range != null && ev.range < f.rangeMin) return false;
      if (f.rangeMin > 0 && ev.range == null) return false;
      if (f.powerMin > 0 && (ev.power == null || ev.power < f.powerMin)) return false;
      if (f.batteryMin > 0 && (ev.battery == null || ev.battery < f.batteryMin)) return false;
      if (f.dcMin > 0 && (ev.dccharger == null || ev.dccharger < f.dcMin)) return false;
      if (f.speedMax < 20 && (ev.speed == null || ev.speed > f.speedMax)) return false;
      if (f.effMax < 350 && (ev.efficiency == null || ev.efficiency > f.effMax)) return false;
      if (f.bootMin > 0 && (ev.boot == null || ev.boot < f.bootMin)) return false;
      if (f.towRequired && (ev.tow_brake == null || ev.tow_brake === 0)) return false;
      if (f.towMin > 0 && (ev.tow_brake == null || ev.tow_brake < f.towMin)) return false;
      if (f.acMin > 0 && (ev.charger == null || ev.charger < f.acMin)) return false;
      if (f.weightMax < 3100 && (ev.weight == null || ev.weight > f.weightMax)) return false;
      if (f.groundMin > 0 && (ev.ground == null || ev.ground < f.groundMin)) return false;
      if (f.lengthMin > 0 && (ev.lengthmm == null || ev.lengthmm < f.lengthMin)) return false;
      if (f.lengthMax < 6000 && (ev.lengthmm == null || ev.lengthmm > f.lengthMax)) return false;
      if (f.widthMax < 2200 && (ev.width == null || ev.width > f.widthMax)) return false;
      if (f.heightMax < 2600 && (ev.height == null || ev.height > f.heightMax)) return false;
      if (f.topspeedMin > 0 && (ev.topspeed == null || ev.topspeed < f.topspeedMin)) return false;
      if (f.torqueMin > 0 && (ev.torque == null || ev.torque < f.torqueMin)) return false;
      if (f.v2lRequired && !ev.v2l) return false;
      if (f.frunkRequired && (ev.frunk == null || ev.frunk === 0)) return false;
      if (chipSelections.make.size > 0 && !chipSelections.make.has(ev.make_name)) return false;
      if (chipSelections.shape.size > 0 && !chipSelections.shape.has(ev.shape)) return false;
      if (chipSelections.drivetrain.size > 0 && !chipSelections.drivetrain.has(ev.drivetrain)) return false;
      if (chipSelections.chem.size > 0 && !chipSelections.chem.has(ev.chem)) return false;
      if (chipSelections.seats.size > 0 && !chipSelections.seats.has(String(ev.seats))) return false;
      if (chipSelections.year.size > 0 && !chipSelections.year.has(ev.year)) return false;
      return true;
    }

    function sortEVs(evs: EV[]) {
      const [field, dir] = filters.sortBy.split("-");
      const mult = dir === "asc" ? 1 : -1;
      return [...evs].sort((a, b) => {
        const va = a[field];
        const vb = b[field];
        if (field === "name") return mult * String(va || "").localeCompare(String(vb || ""));
        if (va == null) return 1;
        if (vb == null) return -1;
        return mult * ((va as number) - (vb as number));
      });
    }

    // --- Render ---
    function renderCard(ev: EV) {
      const imgHtml = ev.image_url
        ? `<img class="ev-card-img" src="${ev.image_url}" alt="${ev.name}" loading="lazy" onerror="this.outerHTML='<div class=\\'ev-card-img placeholder\\'>⚡</div>'">`
        : `<div class="ev-card-img placeholder">⚡</div>`;

      const tags = [];
      if (ev.drivetrain) tags.push(ev.drivetrain);
      if (ev.shape) tags.push(ev.shape);
      if (ev.chem) tags.push(ev.chem);
      if (ev.v2l) tags.push("V2L " + ev.v2l + "kW");
      if (ev.frunk) tags.push("Frunk " + ev.frunk + "L");

      return `
  <a class="ev-card" href="${ev.url || "#"}" target="_blank" rel="noopener">
    ${imgHtml}
    <div class="ev-card-body">
      <div>
        <div class="ev-card-title">${ev.name}</div>
        <div class="ev-card-subtitle">${ev.make_name} ${ev.model_name} · ${ev.year}</div>
      </div>
      <div class="ev-card-price">${fmtPrice(ev.price)}</div>
      <div class="ev-card-specs">
        <div class="spec-item"><span class="spec-label">Range</span><span class="spec-value">${ev.range ? ev.range + " km" : "—"}</span></div>
        <div class="spec-item"><span class="spec-label">Power</span><span class="spec-value">${ev.power ? ev.power + " kW" : "—"}</span></div>
        <div class="spec-item"><span class="spec-label">Battery</span><span class="spec-value">${ev.battery ? ev.battery + " kWh" : "—"}</span></div>
        <div class="spec-item"><span class="spec-label">DC Charge</span><span class="spec-value">${ev.dccharger ? ev.dccharger + " kW" : "—"}</span></div>
        <div class="spec-item"><span class="spec-label">0-100</span><span class="spec-value">${ev.speed ? ev.speed + " s" : "—"}</span></div>
        <div class="spec-item"><span class="spec-label">Efficiency</span><span class="spec-value">${ev.efficiency ? ev.efficiency + " Wh/km" : "—"}</span></div>
        <div class="spec-item"><span class="spec-label">Seats</span><span class="spec-value">${ev.seats || "—"}</span></div>
        <div class="spec-item"><span class="spec-label">Boot</span><span class="spec-value">${ev.boot ? ev.boot + " L" : "—"}</span></div>
        ${ev.tow_brake ? `<div class="spec-item"><span class="spec-label">Tow (braked)</span><span class="spec-value">${ev.tow_brake} kg</span></div>` : ""}
        ${ev.weight ? `<div class="spec-item"><span class="spec-label">Weight</span><span class="spec-value">${ev.weight} kg</span></div>` : ""}
      </div>
      <div class="ev-card-tags">${tags.map((t) => `<span class="tag">${t}</span>`).join("")}</div>
    </div>
  </a>`;
    }

    function applyFilters() {
      const filtered = EV_DATA.filter(matchesFilters);
      const sorted = sortEVs(filtered);

      const countEl = document.getElementById("count");
      if (countEl) countEl.textContent = String(sorted.length);
      const grid = document.getElementById("evGrid");

      if (sorted.length === 0) {
        if (grid) grid.innerHTML = '<div class="no-results">No EVs match your filters. Try adjusting or resetting.</div>';
      } else {
        if (grid) grid.innerHTML = sorted.map(renderCard).join("");
      }
    }

    // --- Sidebar toggle (mobile) ---
    function initSidebarToggle() {
      const btn = document.getElementById("sidebarToggle");
      const sidebar = document.getElementById("sidebar");
      btn?.addEventListener("click", () => sidebar?.classList.toggle("open"));
      document.querySelector(".main")?.addEventListener("click", () => sidebar?.classList.remove("open"));
    }

    // --- Init ---
    initChips();
    initCollapsible();
    initToggles();
    initSliders();
    initSearch();
    initSort();
    initReset();
    initSidebarToggle();
    applyFilters();
  </script>
</BaseLayout>

<style is:global>
  /* Layout */
  .layout {
    display: flex;
    min-height: calc(100vh - 57px);
  }

  /* EV Card styles (rendered via JS so must be global) */
  .ev-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
  }
  .ev-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .ev-card-img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    background: var(--surface2);
  }
  .ev-card-img.placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-dim);
    font-size: 40px;
  }
  .ev-card-body {
    padding: 14px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .ev-card-title {
    font-size: 15px;
    font-weight: 700;
  }
  .ev-card-subtitle {
    font-size: 12px;
    color: var(--text-dim);
  }
  .ev-card-price {
    font-size: 20px;
    font-weight: 800;
    color: var(--green);
  }
  .ev-card-specs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
    font-size: 12px;
  }
  .spec-item {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .spec-label {
    color: var(--text-dim);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .spec-value {
    font-weight: 600;
    font-size: 13px;
  }
  .ev-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: auto;
  }
  .tag {
    font-size: 10px;
    padding: 2px 8px;
    border-radius: 12px;
    background: var(--surface2);
    color: var(--text-dim);
    border: 1px solid var(--border);
  }
  .chip {
    font-size: 12px;
    padding: 4px 10px;
    border-radius: 20px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-dim);
    cursor: pointer;
    transition: all 0.15s;
    user-select: none;
    white-space: nowrap;
  }
  .chip:hover {
    border-color: var(--accent);
    color: var(--text);
  }
  .chip.active {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }
  .no-results {
    grid-column: 1 / -1;
    text-align: center;
    padding: 80px 20px;
    color: var(--text-dim);
    font-size: 16px;
  }

  /* Mobile sidebar toggle */
  .sidebar-toggle {
    display: none;
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 200;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--accent);
    color: #fff;
    border: none;
    font-size: 22px;
    cursor: pointer;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
  }
  @media (max-width: 900px) {
    .sidebar-toggle {
      display: flex;
      align-items: center;
      justify-content: center;
    }
  }
</style>
